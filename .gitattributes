# Auto-detect text files and normalize them to LF line endings in the
# repository, regardless of a contributor's local core.autocrlf setting.
* text=auto eol=lf

# Unix shell scripts must keep LF: a CRLF-corrupted ./mvnw fails to run both
# in the Docker build stage (Alpine sh) and on GitHub Actions (ubuntu-latest).
*.sh text eol=lf
mvnw text eol=lf

# Windows-only scripts keep CRLF.
*.cmd text eol=crlf
*.bat text eol=crlf
mvnw.cmd text eol=crlf

# Source and config files - always LF.
*.java text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md text eol=lf
Dockerfile text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.editorconfig text eol=lf

# Binary files - never modify, never diff as text.
*.jar binary
*.class binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
