root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.java]
indent_size = 4

[*.{yml,yaml}]
indent_size = 2

[*.{json,js,ts,jsx,tsx}]
indent_size = 2

[*.xml]
indent_size = 4

[*.md]
trim_trailing_whitespace = false

[*.{bat,cmd}]
end_of_line = crlf

[Dockerfile]
indent_size = 4
