# -----------------------------------------------------------------------------
# GymTracker - environment configuration template.
#
# Copy this file to ".env" (same directory as docker-compose.yml) and adjust
# values as needed:
#
#   cp .env.example .env
#
# ".env" is gitignored/dockerignored and must never be committed - it is
# where real secrets (production MongoDB credentials, JWT_SECRET, etc.) belong.
# -----------------------------------------------------------------------------

# --- Application server ---
SERVER_PORT=8080

# --- Spring profile: "dev" or "prod" ---
SPRING_PROFILES_ACTIVE=prod

# --- MongoDB connection used by the gymtracker-app container ---
# "mongodb" is the docker-compose service name below; only change the host
# if you rename that service or point at an external MongoDB instance.
MONGODB_URI=mongodb://mongodb:27017/gymtracker
MONGODB_DATABASE=gymtracker

# --- MongoDB container ---
# Host port the mongodb container's 27017 is published on (for local tools
# such as MongoDB Compass/mongosh); change if 27017 is already taken on your host.
MONGODB_PORT=27017
# Named volume used to persist MongoDB data across container restarts/rebuilds.
MONGODB_DATA_VOLUME=gymtracker-mongodb-data

# --- Logging ---
# One of TRACE, DEBUG, INFO, WARN, ERROR. Applies to both root and
# com.gymtracker loggers (see application.properties).
LOG_LEVEL=INFO

# --- Reserved for future use ---
# GymTracker currently uses session-based Spring Security authentication
# (see SecurityConfig), not JWT. This variable is not read by the application
# yet; it is defined here so token-based auth can be wired up later without
# another round of Docker/env-file changes. Set a long random value before
# any real use.
JWT_SECRET=change-me-in-production
